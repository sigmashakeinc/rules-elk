# elk_write_safety.rules
# Technology: elk | Capability: write

rule elk-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_elk_PATTERN"
  MESSAGE "Blocked an unsafe pattern in elk. Use the recommended best practices for 2025/2026."
}

rule elk-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_elk_API"
  MESSAGE "You are using an outdated API for elk. Please upgrade to the newer API."
}
